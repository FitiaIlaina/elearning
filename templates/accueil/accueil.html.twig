{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block header %}
  <nav class="bg-[#0a192f] shadow-lg border-b border-gray-800 sticky top-0 z-50">
    <div class="container mx-auto px-4">
      <div class="flex justify-between items-center py-4">
        <a href="#" class="flex items-center">
          <h1 class="text-2xl md:text-3xl font-bold text-white" style="font-family: 'Cooper Black';">
            E - <span class="text-[#64ffda]">Learning</span>
          </h1>
        </a>
        
        <button class="md:hidden text-white focus:outline-none" id="menu-toggle">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
        
        <ul class="hidden md:flex space-x-6 items-center">
          {% if is_granted('ROLE_ADMIN') %}
            <li>
              <a href="#" class="text-gray-300 hover:text-[#64ffda] transition duration-300 flex items-center">
                <i class="fa fa-home mr-2"></i>Liste des enseignants
              </a>
            </li>
            <li>
              <a href="{{ path('app_eleve') }}" class="text-gray-300 hover:text-[#64ffda] transition duration-300 flex items-center">
                <i class="icon ion-ios-book mr-2"></i>Liste des élèves
              </a>
            </li>
            {% if app.user %}
              <li class="relative group">
                <button class="text-gray-300 hover:text-[#64ffda] transition duration-300 flex items-center">
                  {{ app.user.email }}
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                <div class="absolute right-0 mt-2 w-48 bg-[#112240] border border-gray-700 rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300">
                  <a href="#" id="logout-btn" class="block px-4 py-3 text-gray-300 hover:bg-[#0a192f] hover:text-[#64ffda] rounded-lg transition duration-200">
                    Se déconnecter
                  </a>
                </div>
              </li>
            {% endif %}
          {% elseif is_granted('ROLE_ENSEIGNANT') or is_granted('ROLE_ELEVE') %}
            <li>
              <a href="{{ path('app_accueil') }}" class="text-gray-300 hover:text-[#64ffda] transition duration-300 flex items-center">
                <i class="fa fa-home mr-2"></i>Accueil
              </a>
            </li>
            <li>
              <a href="{{ path('app_cours') }}" class="text-gray-300 hover:text-[#64ffda] transition duration-300 flex items-center">
                <i class="icon ion-ios-book mr-2"></i>Cours
              </a>
            </li>
            {% if app.user %}
              <li class="relative group">
                <button class="text-gray-300 hover:text-[#64ffda] transition duration-300 flex items-center">
                  {{ app.user.email }}
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                <div class="absolute right-0 mt-2 w-48 bg-[#112240] border border-gray-700 rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300">
                  <a href="{{ path('app_profile') }}" class="block px-4 py-3 text-gray-300 hover:bg-[#0a192f] hover:text-[#64ffda] transition duration-200">
                    Voir mon profil
                  </a>
                  <a href="#" id="logout-btn" class="block px-4 py-3 text-gray-300 hover:bg-[#0a192f] hover:text-[#64ffda] rounded-b-lg transition duration-200">
                    Se déconnecter
                  </a>
                </div>
              </li>
            {% endif %}
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>
{% endblock %}

{% block main %}

  {% for message in app.flashes('success') %}
    <div class="bg-green-900 border border-green-600 text-green-100 px-6 py-4 rounded-lg mx-4 mt-4 shadow-lg animate-fade-in">
      {{ message }}
    </div>
  {% endfor %}

  {% if is_granted('ROLE_ADMIN') %}
    <div class="min-h-screen bg-[#020c1b] py-12 px-4">
      <div class="container mx-auto max-w-7xl">
        <div class="bg-[#0a192f] border border-gray-800 rounded-2xl shadow-2xl overflow-hidden">
          <div class="bg-gradient-to-r from-[#112240] to-[#0a192f] px-8 py-6 border-b border-gray-700">
            <h2 class="text-2xl font-bold text-[#64ffda] flex items-center">
              <i class="fa fa-users mr-3"></i>Informations des enseignants
            </h2>
          </div>
          <div class="p-8">
            <div class="overflow-x-auto">
              <table class="w-full">
                <thead>
                  <tr class="border-b-2 border-[#64ffda]">
                    <th class="px-6 py-4 text-left text-[#64ffda] font-semibold uppercase tracking-wider">Email</th>
                    <th class="px-6 py-4 text-left text-[#64ffda] font-semibold uppercase tracking-wider">Nom</th>
                    <th class="px-6 py-4 text-left text-[#64ffda] font-semibold uppercase tracking-wider">Prénom(s)</th>
                    <th class="px-6 py-4 text-left text-[#64ffda] font-semibold uppercase tracking-wider">ID</th>
                  </tr>
                </thead>
                <tbody>
                  {% for inscri in inscription %}
                    {% if 'ROLE_ENSEIGNANT' in inscri.roles %}
                      <tr class="border-b border-gray-800 hover:bg-[#112240] transition duration-200">
                        <td class="px-6 py-4 text-gray-100">{{ inscri.email }}</td>
                        <td class="px-6 py-4 text-gray-100">{{ inscri.name }}</td>
                        <td class="px-6 py-4 text-gray-100">{{ inscri.surname }}</td>
                        <td class="px-6 py-4 text-gray-300 font-mono">{{ inscri.id }}</td>
                      </tr>
                    {% endif %}
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

  {% elseif is_granted('ROLE_ENSEIGNANT') or is_granted('ROLE_ELEVE') %}
    
    {# Hero Section #}
    <section class="relative min-h-screen bg-[#020c1b] flex items-center justify-center overflow-hidden">
      <div id="particles-js" class="absolute inset-0 z-0"></div>
      <div class="container mx-auto px-4 text-center relative z-10">
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-8 animate-fade-in-up">
          Bienvenue sur <br> <span class="text-[#64ffda]">E-Learning</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 mb-12 max-w-3xl mx-auto animate-fade-in-up" style="animation-delay: 0.2s">
          Une plateforme d'éducation en ligne offrant des divers leçons et exercices en ligne
        </p>
        <a href="#about" class="inline-block bg-transparent border-2 border-[#64ffda] text-[#64ffda] px-10 py-4 rounded-lg font-semibold hover:bg-[#64ffda] hover:text-[#0a192f] transition duration-300 transform hover:scale-105 animate-fade-in-up" style="animation-delay: 0.4s">
          Savoir plus <i class="fa fa-angle-double-right ml-2"></i>
        </a>
      </div>
    </section>

    {# About Section #}
    <section id="about" class="bg-[#0a192f] py-20">
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div class="text-white space-y-6">
            <h1 class="text-4xl md:text-6xl font-bold leading-tight">
              Qui<br>sommes-Nous ?<br>
              Pourquoi <span class="text-[#64ffda]">E-Learning</span> ?
            </h1>
          </div>
          <div class="bg-[#112240] border-2 border-gray-800 rounded-2xl overflow-hidden shadow-2xl hover:border-[#64ffda] transition duration-500">
            <div class="relative overflow-hidden group">
              <img src="{{ asset('images/online8.jpg') }}" alt="E-Learning" class="w-full h-64 object-cover transform group-hover:scale-110 transition duration-500">
              <div class="absolute inset-0 bg-gradient-to-t from-[#112240] to-transparent opacity-60"></div>
            </div>
            <div class="p-8">
              <p class="text-gray-300 leading-relaxed text-lg">
                <span class="text-[#64ffda] font-semibold">E-learning</span> est une plateforme qui permet de créer, gérer et diffuser des cours en ligne. <span class="text-[#64ffda] font-semibold">E-learning</span> offre aux apprenants un accès flexible à des contenus éducatifs, des évaluations, et des interactions avec les enseignants, favorisant un apprentissage autonome et interactif.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {# Mission Section #}
    <section class="bg-gradient-to-b from-[#020c1b] to-[#0a192f] py-20">
      <div class="container mx-auto px-4">
        <h2 class="text-4xl md:text-5xl font-bold text-center text-white mb-4">
          QUELLE EST NOTRE <span class="text-[#64ffda]">MISSION</span> ?
        </h2>
        <div class="w-24 h-1 bg-[#64ffda] mx-auto mb-16"></div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="bg-[#0a192f] border-2 border-gray-800 rounded-2xl p-8 text-center hover:border-[#64ffda] hover:transform hover:-translate-y-2 transition-all duration-300 shadow-xl group">
            <div class="w-20 h-20 bg-[#112240] rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-[#64ffda] transition duration-300">
              <i class="fa fa-3x fa-graduation-cap text-[#64ffda] group-hover:text-[#0a192f] transition duration-300"></i>
            </div>
            <h3 class="text-xl font-semibold text-white mb-4">Apprentissage autonome</h3>
            <p class="text-gray-400 leading-relaxed">La promotion de l'apprentissage à son propre rythme, avec une gestion flexible du temps selon les besoins et contraintes personnelles.</p>
          </div>
          
          <div class="bg-[#0a192f] border-2 border-gray-800 rounded-2xl p-8 text-center hover:border-[#64ffda] hover:transform hover:-translate-y-2 transition-all duration-300 shadow-xl group">
            <div class="w-20 h-20 bg-[#112240] rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-[#64ffda] transition duration-300">
              <i class="fa fa-3x fa-cogs text-[#64ffda] group-hover:text-[#0a192f] transition duration-300"></i>
            </div>
            <h3 class="text-xl font-semibold text-white mb-4">Amélioration des compétences</h3>
            <p class="text-gray-400 leading-relaxed">L'appui des élèves à développer des compétences pour progresser dans leur carrière et se distinguer sur le marché du travail.</p>
          </div>
          
          <div class="bg-[#0a192f] border-2 border-gray-800 rounded-2xl p-8 text-center hover:border-[#64ffda] hover:transform hover:-translate-y-2 transition-all duration-300 shadow-xl group">
            <div class="w-20 h-20 bg-[#112240] rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-[#64ffda] transition duration-300">
              <i class="fa fa-3x fa-lightbulb text-[#64ffda] group-hover:text-[#0a192f] transition duration-300"></i>
            </div>
            <h3 class="text-xl font-semibold text-white mb-4">Développement personnel</h3>
            <p class="text-gray-400 leading-relaxed">Inciter les utilisateurs à s'engager dans un apprentissage continu, enrichir leur culture générale et favoriser leur épanouissement.</p>
          </div>
          
          <div class="bg-[#0a192f] border-2 border-gray-800 rounded-2xl p-8 text-center hover:border-[#64ffda] hover:transform hover:-translate-y-2 transition-all duration-300 shadow-xl group">
            <div class="w-20 h-20 bg-[#112240] rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-[#64ffda] transition duration-300">
              <i class="fa fa-3x fa-globe text-[#64ffda] group-hover:text-[#0a192f] transition duration-300"></i>
            </div>
            <h3 class="text-xl font-semibold text-white mb-4">Facilité de l'accès à l'éducation</h3>
            <p class="text-gray-400 leading-relaxed">Assurer que l'apprentissage en ligne soit accessible à un large public, afin de promouvoir l'égalité des chances en matière d'éducation.</p>
          </div>
        </div>
      </div>
    </section>

    {# Matières Section #}
    <section class="bg-[#020c1b] py-24">
  <div class="container mx-auto px-4">
    
    <!-- Titre -->
    <h2 class="text-4xl md:text-5xl font-bold text-center text-gray-100 mb-4">
      LES MATIÈRES <span class="text-[#64ffda]">DISPONIBLES</span>
    </h2>
    <div class="w-24 h-1 bg-[#64ffda] mx-auto mb-20"></div>

    <!-- Grille -->
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">

      {% set sorted_matieres = matieres|sort((a, b) => a.nameles|lower <=> b.nameles|lower) %}
      {% set current_matiere = '' %}

      {% for matiere in sorted_matieres %}
        {% if matiere.nameles|lower != current_matiere|lower %}

          {% if not loop.first %}
              </ul>
            </div>
          {% endif %}

          <div class="bg-[#112240] border border-gray-800 rounded-2xl p-6 shadow-xl
                      hover:border-[#64ffda] hover:-translate-y-2 transition-all duration-300">

            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 bg-[#64ffda] rounded-lg flex items-center justify-center">
                <i class="fa fa-book text-[#020c1b] text-xl"></i>
              </div>
              <h3 class="text-2xl font-semibold text-gray-100">
                {{ matiere.nameles }}
              </h3>
            </div>

            <ul class="space-y-4">
        {% endif %}

        <!-- PDF -->
        <li class="pb-3 border-b border-gray-700 last:border-none">
          <a
            href="{{ path('afficher_pdf', {id: matiere.id}) }}"
            class="group flex items-center text-gray-300 hover:text-[#64ffda] transition"
          >
            <i class="fa fa-file-pdf-o mr-3 text-[#64ffda] opacity-0 group-hover:opacity-100 transition"></i>
            {{ matiere.titleles }}
          </a>

          {% if is_granted('ROLE_ENSEIGNANT') and matiere.createdBy == app.user %}
            <div class="mt-2 flex gap-4 text-xs">
              <a
                href="{{ path('app_matiere_modifier', {id: matiere.id}) }}"
                class="flex items-center text-[#64ffda] hover:text-[#52e8c4]"
              >
                <i class="fa fa-edit mr-1"></i> Modifier
              </a>

              <form method="post"
                    action="{{ path('app_delete', {id: matiere.id}) }}"
                    onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette matière ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ matiere.id) }}">
                <button
                  type="submit"
                  class="flex items-center text-red-400 hover:text-red-300"
                >
                  <i class="fa fa-trash mr-1"></i> Supprimer
                </button>
              </form>
            </div>
          {% endif %}
        </li>

        {% set current_matiere = matiere.nameles %}
        {% if loop.last %}
            </ul>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

  {% endif %}

  {# Footer #}
  <footer class="bg-[#0a192f] border-t-2 border-gray-800 py-12">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-12">
        <div>
          <h1 class="text-3xl font-bold text-white mb-4"  style="font-family: 'Cooper Black';">
            E - <span class="text-[#64ffda]">Learning</span>
          </h1>
          {% if is_granted('ROLE_ADMIN') %}
            <p class="text-gray-400 mb-2">
              <a href="{{ path('app_accueil') }}" class="hover:text-[#64ffda] transition duration-200">Listes des enseignants</a>
              <strong class="text-gray-600"> · </strong>
              <a href="{{ path('app_eleve') }}" class="hover:text-[#64ffda] transition duration-200">Listes des élèves</a>
            </p>
          {% elseif is_granted('ROLE_ENSEIGNANT') or is_granted('ROLE_ELEVE') %}
            <p class="text-gray-400 mb-2">
              <a href="{{ path('app_accueil') }}" class="hover:text-[#64ffda] transition duration-200">Accueil</a>
              <strong class="text-gray-600"> · </strong>
              <a href="{{ path('app_cours') }}" class="hover:text-[#64ffda] transition duration-200">Cours</a>
            </p>
          {% endif %}
          <p class="text-gray-500 text-sm mt-4">E-learning © 2024</p>
        </div>
        
        <div>
          <h4 class="text-xl font-semibold text-white mb-4 flex items-center">
            <i class="fa fa-phone text-[#64ffda] mr-2"></i>Contact
          </h4>
          <div class="space-y-3 text-gray-400">
            <p class="flex items-start">
              <i class="fa fa-map-marker text-[#64ffda] mr-3 mt-1"></i>
              <span>Ivory, Antsirabe</span>
            </p>
            <p class="flex items-center">
              <i class="fa fa-phone text-[#64ffda] mr-3"></i>
              <span>0321245889</span>
            </p>
            <p class="flex items-center">
              <i class="fa fa-envelope text-[#64ffda] mr-3"></i>
              <a href="#" class="hover:text-[#64ffda] transition duration-200">support@company.com</a>
            </p>
          </div>
        </div>
        
        <div>
          <h4 class="text-xl font-semibold text-white mb-4">À propos de E-Learning</h4>
          <p class="text-gray-400 mb-6 leading-relaxed">Une plateforme de site éducatif en ligne qui peut répondre à vos besoins.</p>
          <div class="flex space-x-4">
            <a href="#" class="w-10 h-10 bg-[#112240] rounded-full flex items-center justify-center text-gray-400 hover:bg-[#64ffda] hover:text-[#0a192f] transition duration-300">
              <i class="fa fa-facebook"></i>
            </a>
            <a href="#" class="w-10 h-10 bg-[#112240] rounded-full flex items-center justify-center text-gray-400 hover:bg-[#64ffda] hover:text-[#0a192f] transition duration-300">
              <i class="fa fa-twitter"></i>
            </a>
            <a href="#" class="w-10 h-10 bg-[#112240] rounded-full flex items-center justify-center text-gray-400 hover:bg-[#64ffda] hover:text-[#0a192f] transition duration-300">
              <i class="fa fa-linkedin"></i>
            </a>
            <a href="#" class="w-10 h-10 bg-[#112240] rounded-full flex items-center justify-center text-gray-400 hover:bg-[#64ffda] hover:text-[#0a192f] transition duration-300">
              <i class="fa fa-github"></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  </footer>

  {# Logout Modal #}
  <div id="logout-modal" class="hidden fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center z-50 backdrop-blur-sm">
    <div class="bg-[#0a192f] border-2 border-[#64ffda] rounded-2xl p-8 max-w-md mx-4 shadow-2xl transform animate-fade-in">
      <div class="text-center mb-6">
        <div class="w-16 h-16 bg-[#112240] rounded-full flex items-center justify-center mx-auto mb-4">
          <i class="fa fa-sign-out text-[#64ffda] text-2xl"></i>
        </div>
        <p class="text-gray-100 text-xl font-semibold">Êtes-vous vraiment sûr de vouloir vous déconnecter ?</p>
      </div>
      <div class="flex gap-4">
        <button id="confirm-logout" class="flex-1 bg-[#64ffda] text-[#0a192f] px-6 py-3 rounded-lg font-semibold hover:bg-[#52e8c4] transition duration-300 transform hover:scale-105">
          Oui, déconnecter
        </button>
        <button id="cancel-logout" class="flex-1 bg-gray-700 text-white px-6 py-3 rounded-lg font-semibold hover:bg-gray-600 transition duration-300">
          Annuler
        </button>
      </div>
    </div>
  </div>

  <style>
    @keyframes fade-in-up {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    .animate-fade-in-up {
      animation: fade-in-up 0.8s ease-out forwards;
    }
    .animate-fade-in {
      animation: fade-in-up 0.6s ease-out forwards;
    }
  </style>

  <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
  <script>
    // Particles.js Configuration
    particlesJS('particles-js', {
      particles: {
        number: { value: 100, density: { enable: true, value_area: 800 } },
        color: { value: '#64ffda' },
        shape: { type: 'circle' },
        opacity: { value: 0.3, random: true },
        size: { value: 3, random: true },
        line_linked: { 
          enable: true, 
          distance: 150, 
          color: '#64ffda', 
          opacity: 0.2, 
          width: 1 
        },
        move: { 
          enable: true, 
          speed: 1.5, 
          direction: 'none', 
          random: true, 
          straight: false, 
          out_mode: 'out' 
        }
      },
      interactivity: {
        detect_on: 'canvas',
        events: { 
          onhover: { enable: true, mode: 'grab' }, 
          onclick: { enable: true, mode: 'push' } 
        },
        modes: { 
          grab: { distance: 140, line_linked: { opacity: 0.5 } }, 
          push: { particles_nb: 4 } 
        }
      },
      retina_detect: true
    });

    // Menu Toggle
    document.getElementById('menu-toggle')?.addEventListener('click', function() {
      const menu = document.getElementById('mobile-menu');
      menu?.classList.toggle('hidden');
    });

    // Logout Modal
    document.getElementById('logout-btn')?.addEventListener('click', function(event) {
      event.preventDefault();
      event.stopPropagation();
      document.getElementById('logout-modal').classList.remove('hidden');
    });

    document.getElementById('confirm-logout')?.addEventListener('click', function() {
      window.location.href = "{{ path('app_logout') }}";
    });

    document.getElementById('cancel-logout')?.addEventListener('click', function() {
      document.getElementById('logout-modal').classList.add('hidden');
    });

    // Smooth Scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  </script>
{% endblock %}