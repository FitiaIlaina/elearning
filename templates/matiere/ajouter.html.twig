{% extends 'base.html.twig' %}

{% block title %}
    Ajouter des matières
{% endblock %}

{% block header %}
  
        <nav class="bg-[#0a192f] shadow-lg border-b border-gray-800 sticky top-0 z-50">
    <div class="container mx-auto px-4">
      <div class="flex justify-between items-center py-4">
        <a href="#" class="flex items-center">
          <h1 class="text-2xl md:text-3xl font-bold text-white"style="font-family: 'Cooper Black';">
            E - <span class="text-[#64ffda]">Learning</span>
          </h1>
        </a>
        
        <button class="md:hidden text-white focus:outline-none" id="menu-toggle">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
        
        <ul class="hidden md:flex space-x-6 items-center">
          {% if is_granted('ROLE_ADMIN') %}
            <li>
              <a href="#" class="text-gray-300 hover:text-[#64ffda] transition duration-300 flex items-center">
                <i class="fa fa-home mr-2"></i>Liste des enseignants
              </a>
            </li>
            <li>
              <a href="{{ path('app_eleve') }}" class="text-gray-300 hover:text-[#64ffda] transition duration-300 flex items-center">
                <i class="icon ion-ios-book mr-2"></i>Liste des élèves
              </a>
            </li>
            {% if app.user %}
              <li class="relative group">
                <button class="text-gray-300 hover:text-[#64ffda] transition duration-300 flex items-center">
                  {{ app.user.email }}
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                <div class="absolute right-0 mt-2 w-48 bg-[#112240] border border-gray-700 rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300">
                  <a href="#" id="logout-btn" class="block px-4 py-3 text-gray-300 hover:bg-[#0a192f] hover:text-[#64ffda] rounded-lg transition duration-200">
                    Se déconnecter
                  </a>
                </div>
              </li>
            {% endif %}
          {% elseif is_granted('ROLE_ENSEIGNANT') or is_granted('ROLE_ELEVE') %}
            <li>
              <a href="{{ path('app_accueil') }}" class="text-gray-300 hover:text-[#64ffda] transition duration-300 flex items-center">
                <i class="fa fa-home mr-2"></i>Accueil
              </a>
            </li>
            <li>
              <a href="{{ path('app_cours') }}" class="text-gray-300 hover:text-[#64ffda] transition duration-300 flex items-center">
                <i class="icon ion-ios-book mr-2"></i>Cours
              </a>
            </li>
            {% if app.user %}
              <li class="relative group">
                <button class="text-gray-300 hover:text-[#64ffda] transition duration-300 flex items-center">
                  {{ app.user.email }}
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                <div class="absolute right-0 mt-2 w-48 bg-[#112240] border border-gray-700 rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300">
                  <a href="{{ path('app_profile') }}" class="block px-4 py-3 text-gray-300 hover:bg-[#0a192f] hover:text-[#64ffda] transition duration-200">
                    Voir mon profil
                  </a>
                  <a href="#" id="logout-btn" class="block px-4 py-3 text-gray-300 hover:bg-[#0a192f] hover:text-[#64ffda] rounded-b-lg transition duration-200">
                    Se déconnecter
                  </a>
                </div>
              </li>
            {% endif %}
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>
   
 {% endblock %}

{% block main %}
<section class="register-photo bg-[#020c1b] min-h-screen py-12">
    <div class="text-center py-8">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-100">
      Ajouter <span class="text-[#64ffda]">des matières</span>
    </h1>
    <div class="w-20 h-1 bg-[#64ffda] mx-auto mt-6"></div>
    </div>
    
    <div class="form-container max-w-4xl mx-auto px-4">
        <div class="bg-[#0a192f] rounded-2xl border-2 border-gray-700 shadow-2xl p-8">
            {{ form_start(form) }}
            
            <div class="form-group mb-6">
                <label class="block text-gray-300 font-semibold mb-2 text-lg">
                    {{ form_label(form.nameles) }}
                </label>
                {{ form_widget(form.nameles, { 'attr': {'class': 'w-full bg-[#112240] border-2 border-gray-700 rounded-lg px-4 py-3 text-gray-100 focus:border-[#64ffda] focus:outline-none transition duration-300 placeholder-gray-500'}}) }}
                {{ form_errors(form.nameles) }}
            </div>

            <div class="form-group mb-6">
                <label class="block text-gray-300 font-semibold mb-2 text-lg">
                    {{ form_label(form.titleles) }}
                </label>
                {{ form_widget(form.titleles, { 'attr': {'class': 'w-full bg-[#112240] border-2 border-gray-700 rounded-lg px-4 py-3 text-gray-100 focus:border-[#64ffda] focus:outline-none transition duration-300 placeholder-gray-500'}}) }}
                {{ form_errors(form.titleles) }}
            </div>

            <div class="form-group mb-6">
                <label class="block text-gray-300 font-semibold mb-2 text-lg">
                    {{ form_label(form.fichier) }}
                </label>
                {{ form_widget(form.fichier, {'attr': {'class': 'w-full bg-[#112240] border-2 border-gray-700 rounded-lg px-4 py-3 text-gray-100 focus:border-[#64ffda] focus:outline-none transition duration-300 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-[#64ffda] file:text-[#020c1b] file:font-semibold hover:file:bg-[#52e8c4] file:cursor-pointer'}}) }}
                {{ form_errors(form.fichier) }}
            </div>

            <div class="form-group mb-8">
                <label class="block text-gray-300 font-semibold mb-2 text-lg">
                    {{ form_label(form.video) }}
                </label>
                {{ form_widget(form.video, {'attr': {'class': 'w-full bg-[#112240] border-2 border-gray-700 rounded-lg px-4 py-3 text-gray-100 focus:border-[#64ffda] focus:outline-none transition duration-300 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-[#64ffda] file:text-[#020c1b] file:font-semibold hover:file:bg-[#52e8c4] file:cursor-pointer'}}) }}
                {{ form_errors(form.video) }}
            </div>

            <div id="questions-container" class="mb-8">
                <div class="bg-[#112240] border-2 border-[#64ffda] rounded-lg p-4 mb-6">
                    <p class="text-[#64ffda] font-semibold text-lg">
                        <i class="fas fa-question-circle mr-2"></i>Contenu des questions : {{ form.questions|length }}
                    </p>
                </div>

                {% for questionForm in form.questions %}
                    <div class="question bg-[#112240] rounded-xl border-2 border-gray-700 p-6 mb-6 hover:border-[#64ffda] transition duration-300">
                        <h4 class="text-2xl font-bold text-[#64ffda] mb-6 pb-3 border-b border-gray-600">
                            <i class="fas fa-clipboard-question mr-2"></i>Question {{ loop.index }}
                        </h4>
                        
                        <div class="form-group mb-4">
                            <label class="block text-gray-300 font-semibold mb-2">
                                {{ form_label(questionForm.question) }}
                            </label>
                            {{ form_widget(questionForm.question, { 'attr': { 'class': 'w-full bg-[#0a192f] border-2 border-gray-700 rounded-lg px-4 py-3 text-gray-100 focus:border-[#64ffda] focus:outline-none transition duration-300 placeholder-gray-500' } }) }}
                            {{ form_errors(questionForm.question) }}
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                            <div class="form-group">
                                <label class="block text-gray-300 font-semibold mb-2">
                                    {{ form_label(questionForm.optionA) }}
                                </label>
                                {{ form_widget(questionForm.optionA, { 'attr': { 'class': 'w-full bg-[#0a192f] border-2 border-gray-700 rounded-lg px-4 py-3 text-gray-100 focus:border-[#64ffda] focus:outline-none transition duration-300 placeholder-gray-500' } }) }}
                                {{ form_errors(questionForm.optionA) }}
                            </div>

                            <div class="form-group">
                                <label class="block text-gray-300 font-semibold mb-2">
                                    {{ form_label(questionForm.optionB) }}
                                </label>
                                {{ form_widget(questionForm.optionB, { 'attr': { 'class': 'w-full bg-[#0a192f] border-2 border-gray-700 rounded-lg px-4 py-3 text-gray-100 focus:border-[#64ffda] focus:outline-none transition duration-300 placeholder-gray-500' } }) }}
                                {{ form_errors(questionForm.optionB) }}
                            </div>

                            <div class="form-group">
                                <label class="block text-gray-300 font-semibold mb-2">
                                    {{ form_label(questionForm.optionC) }}
                                </label>
                                {{ form_widget(questionForm.optionC, { 'attr': { 'class': 'w-full bg-[#0a192f] border-2 border-gray-700 rounded-lg px-4 py-3 text-gray-100 focus:border-[#64ffda] focus:outline-none transition duration-300 placeholder-gray-500' } }) }}
                                {{ form_errors(questionForm.optionC) }}
                            </div>

                            <div class="form-group">
                                <label class="block text-gray-300 font-semibold mb-2">
                                    {{ form_label(questionForm.optionD) }}
                                </label>
                                {{ form_widget(questionForm.optionD, { 'attr': { 'class': 'w-full bg-[#0a192f] border-2 border-gray-700 rounded-lg px-4 py-3 text-gray-100 focus:border-[#64ffda] focus:outline-none transition duration-300 placeholder-gray-500' } }) }}
                                {{ form_errors(questionForm.optionD) }}
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="block text-gray-300 font-semibold mb-2">
                                {{ form_label(questionForm.correctOption) }}
                            </label>
                            {{ form_widget(questionForm.correctOption, { 'attr': { 'class': 'w-full bg-[#0a192f] border-2 border-gray-700 rounded-lg px-4 py-3 text-gray-100 focus:border-[#64ffda] focus:outline-none transition duration-300' } }) }}
                            {{ form_errors(questionForm.correctOption) }}
                        </div>
                    </div>
                {% endfor %}
            </div>

            <div class="form-group">
                <button type="submit" class="w-full bg-[#112240] hover:bg-[#64ffda] hover:text-[#020c1b] text-gray-100 font-bold text-lg px-8 py-4 rounded-lg border-2 border-[#64ffda] transition duration-300 shadow-lg">
                    <i class="fas fa-save mr-2"></i>Enregistrer
                </button>
            </div>
        
            {{ form_end(form) }}
        </div>
    </div>
</section>

<footer class="bg-[#0a192f] border-t border-gray-800 py-12">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="footer-navigation">
                <h1 class="text-2xl md:text-3xl font-bold text-white mb-4" style="font-family: 'Cooper Black';">
                    E - <span class="text-[#64ffda]">Learning</span>
                </h1>
                <p class="links mb-3">
                    <a href="{{ path('app_accueil') }}" class="text-gray-300 hover:text-[#52e8c4] transition duration-300">Accueil</a>
                    <strong class="text-gray-500 mx-2">·</strong>
                    <a href="{{ path('app_cours') }}" class="text-gray-300 hover:text-[#52e8c4] transition duration-300">Cours</a>
                </p>
                <p class="company-name text-gray-400">E-learning © 2024</p>
            </div>

            <div class="footer-contacts space-y-3">
                <div class="flex items-start">
                    <span class="fa fa-map-marker text-[#64ffda] mr-3 mt-1"></span>
                    <p class="text-gray-300">
                        <span class="block">Ivory</span>
                        Antsirabe
                    </p>
                </div>
                <div class="flex items-center">
                    <i class="fa fa-phone text-[#64ffda] mr-3"></i>
                    <p class="text-gray-300">0321245889</p>
                </div>
                <div class="flex items-center">
                    <i class="fa fa-envelope text-[#64ffda] mr-3"></i>
                    <p>
                        <a href="#" target="_blank" class="text-gray-300 hover:text-[#52e8c4] transition duration-300">support@company.com</a>
                    </p>
                </div>
            </div>

            <div class="footer-about">
                <h4 class="text-xl text-gray-100 font-semibold mb-4">À propos de E-Learning</h4>
                <p class="text-gray-300 mb-4">Une plateforme de site éducatif en ligne qui peut répondre à vos besoins.</p>
                <div class="social-links social-icons flex gap-4">
                    <a href="#" class="text-gray-400 hover:text-[#64ffda] transition duration-300 text-xl">
                        <i class="fa fa-facebook"></i>
                    </a>
                    <a href="#" class="text-gray-400 hover:text-[#64ffda] transition duration-300 text-xl">
                        <i class="fa fa-twitter"></i>
                    </a>
                    <a href="#" class="text-gray-400 hover:text-[#64ffda] transition duration-300 text-xl">
                        <i class="fa fa-linkedin"></i>
                    </a>
                    <a href="#" class="text-gray-400 hover:text-[#64ffda] transition duration-300 text-xl">
                        <i class="fa fa-github"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</footer>

<script>
    document.getElementById('logout-btn').addEventListener('click', function(event) {
        event.preventDefault(); 
        event.stopPropagation();
        const modal = document.getElementById('logout-modal');
        modal.style.display = 'flex';
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    });

    document.getElementById('confirm-logout').addEventListener('click', function() {
        window.location.href = "{{ path('app_logout') }}";
    });

    document.getElementById('cancel-logout').addEventListener('click', function() {
        const modal = document.getElementById('logout-modal');
        modal.style.display = 'none';
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    });
</script>

{% endblock %}