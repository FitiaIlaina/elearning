{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block header %}
  <nav class="bg-[#0a192f] shadow-lg border-b border-gray-800">
    <div class="container mx-auto px-4">
      <div class="flex justify-between items-center py-4">
        <a href="#" class="flex items-center">
          <h1 class="text-2xl md:text-3xl font-bold text-white">
            E - <span class="text-[#64ffda]">Learning</span>
          </h1>
        </a>
        
        <button class="md:hidden text-white focus:outline-none" id="menu-toggle">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
        
        <ul class="hidden md:flex space-x-6 items-center">
          <li>
            <a href="{{ path('app_register') }}" class="text-gray-300 hover:text-[#64ffda] transition duration-300">
              S'inscrire
            </a>
          </li>
          <li>
            <a href="{{ path('app_login') }}" class="bg-[#112240] text-[#64ffda] border border-[#64ffda] px-6 py-2 rounded-lg font-semibold hover:bg-[#64ffda] hover:text-[#0a192f] transition duration-300">
              Se connecter
            </a>
          </li>
        </ul>
      </div>
      
      <div class="hidden md:hidden pb-4" id="mobile-menu">
        <ul class="space-y-2">
          <li>
            <a href="{{ path('app_register') }}" class="block text-gray-300 hover:text-[#64ffda] transition duration-300">
              S'inscrire
            </a>
          </li>
          <li>
            <a href="{{ path('app_login') }}" class="block text-gray-300 hover:text-[#64ffda] transition duration-300">
              Se connecter
            </a>
          </li>
        </ul>
      </div>
    </div>
  </nav>
{% endblock %}

{% block main %}
  <section class="min-h-screen bg-[#020c1b] py-12 px-4">
    <div class="container mx-auto max-w-6xl">
      
      {% if error %}
        <div class="bg-red-900 border border-red-600 text-red-100 px-6 py-4 rounded-lg mb-6 shadow-lg">
          {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
      {% endif %}

      {% if app.user %}
        <div class="bg-[#112240] border border-[#64ffda] text-gray-100 px-6 py-4 rounded-lg mb-6 shadow-lg">
          Vous êtes connecté(e) en tant que {{ app.user.userIdentifier }}, 
          <a href="{{ path('app_logout') }}" class="underline hover:text-[#64ffda] text-[#64ffda]">Se déconnecter</a>
        </div>
      {% endif %}

      <div class="grid md:grid-cols-2 gap-8 items-center">
        
        <div class="hidden md:block">
          <div class="bg-gradient-to-br from-[#0a192f] to-[#112240] border border-gray-800 rounded-2xl shadow-2xl p-12 h-full min-h-[500px] flex items-center justify-center">
            <div class="text-center">
              <svg class="w-64 h-64 mx-auto text-[#64ffda] opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
              <h2 class="text-3xl font-bold text-gray-100 mt-8">Bienvenue sur E-Learning</h2>
              <p class="text-gray-400 mt-4">Accédez à vos cours en ligne</p>
            </div>
          </div>
        </div>

        <div class="bg-[#0a192f] border border-gray-800 rounded-2xl shadow-2xl p-8 md:p-12">
          <h2 class="text-3xl font-bold text-gray-100 text-center mb-8">
            Connectez-vous
          </h2>

          <form method="post" action="{{ path('app_login') }}" class="space-y-6">
            
            <div>
              <label for="inputEmail" class="block text-sm font-semibold text-gray-300 mb-2">
                Adresse email
              </label>
              <input 
                type="email" 
                value="{{ last_username }}" 
                name="email" 
                id="inputEmail" 
                placeholder="votre@email.com"
                autocomplete="email" 
                required 
                autofocus
                class="w-full px-4 py-3 bg-[#112240] border-2 border-gray-700 text-gray-100 rounded-lg focus:outline-none focus:border-[#64ffda] transition duration-300 placeholder-gray-500"
              >
            </div>

            <div>
              <label for="inputPassword" class="block text-sm font-semibold text-gray-300 mb-2">
                Mot de passe
              </label>
              <input 
                type="password" 
                name="password" 
                id="inputPassword" 
                placeholder="••••••••"
                autocomplete="current-password" 
                required
                class="w-full px-4 py-3 bg-[#112240] border-2 border-gray-700 text-gray-100 rounded-lg focus:outline-none focus:border-[#64ffda] transition duration-300 placeholder-gray-500"
              >
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="flex items-center">
              <input 
                type="checkbox" 
                name="_remember_me" 
                id="remember_me"
                class="w-4 h-4 text-[#64ffda] bg-[#112240] border-gray-700 rounded focus:ring-[#64ffda]"
              >
              <label for="remember_me" class="ml-2 text-sm text-gray-300">
                Se souvenir de moi
              </label>
            </div>

            <button 
              type="submit"
              class="w-full bg-[#112240] border-2 border-[#64ffda] text-[#64ffda] py-3 rounded-lg font-semibold hover:bg-[#64ffda] hover:text-[#0a192f] transition duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              Se connecter
            </button>

            <div class="text-center mt-6">
              <a 
                href="{{ path('app_register') }}" 
                class="text-[#64ffda] hover:text-[#52e8c4] font-medium transition duration-300"
              >
                Vous n'avez pas encore de compte? Cliquez-ici
              </a>
            </div>
          </form>
        </div>

      </div>
    </div>
  </section>

  <script>
    document.getElementById('menu-toggle')?.addEventListener('click', function() {
      const menu = document.getElementById('mobile-menu');
      menu.classList.toggle('hidden');
    });
  </script>
{% endblock %}